<?xml version="1.0" encoding="utf-8"?>
<!--
    Auto Backup rules (pre-Android 12 fallback).
    We intentionally do NOT back up:
      - DataStore preferences (holds user-tunable settings)
      - Room database (holds local copies of transactions, dairy logs, etc.)
    because restoring them to a different install / device could mix
    household data across accounts and defeat server-side identity scoping.
-->
<full-backup-content>
    <exclude domain="file" path="datastore/household_settings.preferences_pb" />
    <exclude domain="database" path="household_ledger_db" />
    <exclude domain="database" path="household_ledger_db-journal" />
    <exclude domain="database" path="household_ledger_db-shm" />
    <exclude domain="database" path="household_ledger_db-wal" />
</full-backup-content>
