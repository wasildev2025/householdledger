<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ data extraction rules. Matches backup_rules.xml:
    Room DB and DataStore are excluded from both cloud backup and
    device-to-device transfer to prevent cross-account data mixing.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="datastore/household_settings.preferences_pb" />
        <exclude domain="database" path="household_ledger_db" />
        <exclude domain="database" path="household_ledger_db-journal" />
        <exclude domain="database" path="household_ledger_db-shm" />
        <exclude domain="database" path="household_ledger_db-wal" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="datastore/household_settings.preferences_pb" />
        <exclude domain="database" path="household_ledger_db" />
        <exclude domain="database" path="household_ledger_db-journal" />
        <exclude domain="database" path="household_ledger_db-shm" />
        <exclude domain="database" path="household_ledger_db-wal" />
    </device-transfer>
</data-extraction-rules>
